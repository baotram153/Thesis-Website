---
import type { HTMLAttributes } from "astro/types";
interface Props extends HTMLAttributes<"video"> {
  src: string;
  square?: boolean;
}

const {
  src,
  square = false,
  controls = true,
  loop = true,
  playsinline = true,
  muted = true,
  autoplay = true,
  class: className,
  ...videoProps
} = Astro.props;
---

<video
  class:list={[
    "h-auto w-full rounded-lg",
    square ? "aspect-square object-cover" : "aspect-video",
    className,
  ]}
  src={src}
  controls={controls}
  loop={loop}
  playsinline={playsinline}
  muted={muted}
  autoplay={autoplay}
  {...videoProps}></video>
